
# =================================================================
# GLOBAL CONFIGURATION - CUMBRE INFRASTRUCTURE
# =================================================================
# Este archivo centraliza TODA la configuración de red y dominios.
# Si necesitas desplegar en otra ciudad con otro rango IP,
# SOLO MODIFICA ESTE ARCHIVO.

# -----------------
# 1. Red Base
# -----------------
# Interfaz de red de las VMs (generalmente ens18 en Proxmox)
NET_IFACE="ens18"

# Puerta de Enlace (Router)
GATEWAY="192.168.99.1"

# DNS Externo para resolución pública (Google, Cloudflare, ISP)
DNS_FORWARDER="8.8.8.8"

# Máscara de Red (Notación CIDR)
NETMASK="24"

# -----------------
# 2. Dominios
# -----------------
DOMAIN_MAIN="cumbre.edu.bo"
DOMAIN_SEC="institutocumbre.edu.bo"

# -----------------
# 3. Direccionamiento IP (Estático)
# -----------------
# IMPORTANTE: Asegúrate de que estas IPs estén libres en tu red.

# Servidor DNS (dns01) - ESTE SERVIDOR
IP_DNS="192.168.99.131"
HOSTNAME_DNS="dns01.local"

# Servidor Gateway / Túnel Cloudflare (gw01)
IP_TUNNEL="192.168.99.130"
HOSTNAME_TUNNEL="gw01.local"

# Servidor Web / Portal (web01)
IP_WEB="192.168.99.132"
HOSTNAME_WEB="web01.local"

# Servidor SIS (sis01)
IP_SIS="192.168.99.133"
HOSTNAME_SIS="sis01.local"

# Servidor SIS Legado (sis-legacy) - CentOS 7 + PHP 5
IP_SIS_LEGACY="192.168.99.136"
HOSTNAME_SIS_LEGACY="sis-legacy.local"

# Servidor LMS / Moodle (lms01)
IP_LMS="192.168.99.134"
HOSTNAME_LMS="lms01.local"

# Servidor NAS / Backups (nas01)
IP_NAS="192.168.99.135"
HOSTNAME_NAS="nas01.local"

# -----------------
# 4. Configuración Services (Opcional)
# -----------------
DB_ROOT_PASS="Cumbre2026Secure"
MOODLE_DB_PASS="MoodleUserPass2026"
